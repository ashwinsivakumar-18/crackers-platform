NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# CORS — the React apps
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# MongoDB (local, or a MongoDB Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/crackers

# Redis (cache + queue)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP
OTP_TTL_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# Object storage (S3 / MinIO) — optional in dev
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=crackers-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=http://localhost:9000/crackers-media

# WhatsApp (optional in dev — logs instead of sends)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

STORE_NAME=Sri Lakshmi Crackers
STORE_UPI_ID=yourstore@okhdfc
